rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Тимчасово: дозволяємо всім авторизованим користувачам писати
    match /users/{uid} {
      allow read, write: if request.auth != null;
    }

    match /goals/{goalId} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
